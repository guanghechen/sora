{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "guanghechen",
    "url": "https://github.com/guanghechen/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guanghechen/sora/tree/release-2.x.x"
  },
  "homepage": "https://github.com/guanghechen/sora/tree/release-2.x.x/#readme",
  "type": "module",
  "scripts": {
    ":publish": "pnpm clean && pnpm build:production && pnpm test:coverage && changeset publish",
    ":publish:all": "pnpm -r exec npm version patch --no-git-tag-version && pnpm -r publish --no-git-checks",
    ":version": "changeset version",
    ":upgrade": "pnpm update -i && pnpm clean && pnpm format && pnpm build && pnpm test",
    "build": "cross-env NODE_ENV=production SOURCEMAP=true pnpm -r run build",
    "build:production": "cross-env NODE_ENV=production SOURCEMAP=false pnpm -r run build",
    "clean": "pnpm -r run clean && pnpm install",
    "format": "pnpm format:lintfix && pnpm format:prettier",
    "format:prettier": "prettier . --write",
    "format:lintfix": "eslint . --fix",
    "postinstall": "node packages/githooks/cli.mjs install",
    "rebuild": "pnpm clean && pnpm build",
    "test": "pnpm -r run --if-present test",
    "test:coverage": "pnpm -r run --if-present test:coverage",
    "test:update": "pnpm -r run --if-present test:update",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "version": "pnpm install && node script/sync-doc-link.mjs && git stage -u pnpm-lock.yaml packages/**/package.json packages/**/*.md"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@guanghechen/githooks": "workspace:^",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "cross-env": "10.1.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.17.1",
    "globals": "17.7.0",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "rimraf": "6.1.3",
    "tsdown": "0.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "githooks": {
    "hooks": {
      "pre-commit": "pnpm exec lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,mts,cjs,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,eslintrc}": [
      "prettier --write"
    ]
  }
}
